---
const navLinks = [
  { label: 'Build', href: 'https://studio.openxai.org' },
  { label: 'Community', href: 'https://community.openxai.org' },
  { label: 'Docs', href: 'https://docs.openxai.org' },
];
---
<nav class="fixed top-0 inset-x-0 z-50 h-16 backdrop-blur bg-brand-bg/70 border-b border-white/5">
  <div class="max-w-7xl mx-auto h-full px-6 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-brand-fg">OpenxAI</a>

    <ul class="hidden md:flex items-center gap-8 text-sm text-brand-fg/80">
      {navLinks.map(({ label, href }) => (
        <li><a href={href} class="hover:text-brand-fg transition-colors">{label}</a></li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="https://dexscreener.com/base/0x7ad1db1b8a8ce3040bc1807d7af6a8bc88584600"
        target="_blank"
        rel="noopener"
        class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 text-xs text-brand-fg/80 hover:text-brand-fg hover:border-white/20 transition-colors"
      >
        <span class="text-brand-orange">$OPENX</span>
        <span class="font-medium">$0.03</span>
      </a>
      <a
        href="https://studio.openxai.org"
        class="px-4 py-1.5 rounded-full bg-brand-fg text-brand-bg text-sm font-medium hover:bg-white/90 transition-colors"
      >
        Launch
      </a>
    </div>
  </div>
</nav>
