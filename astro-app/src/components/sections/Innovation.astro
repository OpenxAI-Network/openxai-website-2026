---
import CounterAnimation from "@/components/CounterAnimation.tsx";
import Reveal from "@/components/Reveal.tsx";

const breakthroughs = [
  { title: 'Cost & Energy Reduction', desc: 'Cut AI costs by 80% with decentralized GPUs.' },
  { title: 'Model Ownership',         desc: 'Tokenize models and keep full rights and royalties.' },
  { title: 'Censorship Resistance',   desc: 'AI that no one can stop or control.' },
];

const stats = [
  { v: 8.2, label: 'Cost Multiplier' },
  { v: 3.6, label: 'Energy Reduction' },
  { v: 3.1, label: 'Throughput' },
  { v: 3.2, label: 'Latency' },
  { v: 2.8, label: 'Composability' },
];
---
<section class="px-4 md:px-6 py-12 bg-brand-bg">
  <Reveal client:visible className="max-w-7xl mx-auto rounded-4xl bg-brand-ink-2 px-6 md:px-16 py-20 md:py-28">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-fg/55 mb-8">Innovation &amp; Breakthroughs</p>
    <h2 class="font-medium leading-[1.05] tracking-[-0.02em] text-3xl md:text-5xl lg:text-6xl text-brand-fg max-w-5xl">
      AI's complexity excludes non-coders and 3B+ people, leaving its potential untapped.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-16">
      {breakthroughs.map((b) => (
        <article class="p-8 rounded-3xl bg-brand-bg ring-1 ring-white/10">
          <h3 class="text-xl md:text-2xl font-medium tracking-[-0.01em] text-brand-fg">{b.title}</h3>
          <p class="mt-4 text-brand-fg/65 leading-relaxed">{b.desc}</p>
        </article>
      ))}
    </div>

    <div class="mt-20 grid grid-cols-2 md:grid-cols-5 gap-y-10 gap-x-6">
      {stats.map((s) => (
        <div class="text-center md:text-left">
          <div class="text-4xl md:text-5xl font-medium tracking-[-0.02em] text-brand-orange">
            <CounterAnimation client:visible to={s.v} decimals={1} suffix="x" />
          </div>
          <p class="mt-2 text-xs md:text-sm text-brand-fg/60">{s.label}</p>
        </div>
      ))}
    </div>
  </Reveal>
</section>
