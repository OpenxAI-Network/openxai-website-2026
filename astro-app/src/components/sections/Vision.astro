---
import Reveal from "@/components/Reveal.tsx";
---
<section id="vision" class="px-4 md:px-6 py-12 bg-brand-bg">
  <Reveal client:visible className="max-w-7xl mx-auto rounded-4xl bg-brand-panel text-brand-ink px-6 md:px-16 py-20 md:py-32">
    <p class="text-xs uppercase tracking-[0.25em] text-brand-ink-3 mb-8">OpenxAI Vision</p>
    <h2 class="font-medium leading-[1.05] tracking-[-0.02em] text-3xl md:text-5xl lg:text-6xl text-brand-ink max-w-5xl">
      AI is humanity's most powerful technology, yet it remains centralized, expensive, and locked away from billions.
    </h2>
    <p class="mt-10 text-lg md:text-xl text-brand-ink-3 max-w-3xl leading-relaxed">
      OpenxAI exists to change this. We make intelligence open, programmable, and liquid.
      Anyone, anywhere can create, own, consume, and exchange AI as a shared global utility.
    </p>
    <a
      href="https://medium.com/openxai/why-permissionless-ai"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 mt-12 px-6 py-3 rounded-full bg-brand-ink text-brand-fg hover:bg-brand-ink/85 transition-colors text-sm font-medium"
    >
      Read full vision <span aria-hidden="true">→</span>
    </a>
  </Reveal>
</section>
