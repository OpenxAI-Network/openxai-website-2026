            if (filtersChanged) {
              sessionStorage.setItem('fc_filters', JSON.stringify(newFilters));
              // Force refresh from Shopify if filters changed
              products = [];
              return fetchProductsByCountry(countryCode, null, vendor, collection, productType, tag);
            }
          } catch (error) {
