            if (tag) queryParts.push(`tag:${tag}`);
            const queryString = queryParts.length > 0 ? queryParts.join(" AND ") : null;

            variables = {
              countryCode,
              ...(cursor && { cursor }),
              ...(queryString && { query: queryString })
            };
