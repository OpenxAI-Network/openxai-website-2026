copeId\":\"contentManagement\"},[4,\"a\",null,[5,\"Handbrake\"]]],[5,\" with “Web Optimized” settings.\"]]]]],[4,\"li\",{\"data-preset-tag\":\"p\"},[4,\"p\",null,[4,\"strong\",null,[5,\"Choose a well-supported file format and codec.\"]],[5,\" For example, the AV1 codec is not supported on some older iOS or Mac versions. The H.264 codec with the “.mp4” file extension is universally supported across browsers.\"]]],[4,\"li\",{\"data-preset-tag\":\"p\"},[4,\"p\",null,[4,\"em\",null,[5,\"For advanced users:\"]],[5,\" When using ffmpeg, include the flag \"],[4,\"code\",null,[5,\"movflags +faststart\"]],[5,\" to allow videos to play faster in browsers.\"]]]],[4,\"p\",{\"dir\":\"auto\"},[4,\"strong\",null,[5,\"Note: \"]],[5,\"Keep looping videos \"],[4,\"strong\",null,[5,\"under 5 MB\"]],[5,\" in size. Most browsers have a \"],[4,\"strong\",null,[5,\"5–8 MB caching limit\"]],[5,\" for media files, meaning larger videos won’t stay cached and will be \"],[4,\"strong\",null,[5,\"re-downloaded each time\"]],[5,\" they play, increasing bandwidth usage.\"]],[4,\"h3\",{\"dir\":\"auto\"},[5,\"Why Framer does not optimize the video file\"]],[4,\"p\",{\"dir\":\"auto\"},[5,\"Video optimization is complex and costly. To do it effectively, we’d need to build infrastructure similar to YouTube or Vimeo from scratch. Instead, we focus on what we do best: helping you create exceptional websites.\"]],[4,\"p\",{\"dir\":\"auto\"},[5,\"Still experiencing the issue after following the steps above? Feel free to reach out to us through our \"],[2,{\"href\":{\"webPageId\":\"Ln6ft6x8F\"},\"openInNewTab\":false,\"smoothScroll\":false,\"relValues\":[],\"motionChild\":true,\"nodeId\":\"t9gvWQQj9\",\"scopeId\":\"contentManagement\"},[4,\"a\",null,[5,\"contact\"]]],[5,\" page for further help.\"]]]",{"type":9,"value":26},"How does Framer optimize video loading and playback on websites?",{"type":21,"value":28},{"collectionId":23,"pointer":29},"[1,[4,\"p\",{\"dir\":\"auto\"},[5,\"Framer uses several optimi