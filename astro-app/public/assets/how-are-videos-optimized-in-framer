          // Store products in smaller chunks to avoid quota issues
          const CHUNK_SIZE = 50;
          const chunks = [];
          for (let i = 0; i < products.length; i += CHUNK_SIZE) {
            chunks.push(products.slice(i, i + CHUNK_SIZE));
          }

          let storageQuotaExceeded = false;

          // Update storage with all chunks
          try {
