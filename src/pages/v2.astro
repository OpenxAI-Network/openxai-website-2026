---
import RootLayout       from "@/layouts/RootLayout.astro";
import Nav              from "@/components/Nav.astro";
import Hero             from "@/components/Hero.astro";
import Vision           from "@/components/sections/Vision.astro";
import Metrics          from "@/components/sections/Metrics.astro";
import TechEvolution    from "@/components/sections/TechEvolution.astro";
import TechStack        from "@/components/sections/TechStack.astro";
import Features         from "@/components/sections/Features.astro";
import EndToEndStack    from "@/components/sections/EndToEndStack.astro";
import CoreProduct      from "@/components/sections/CoreProduct.astro";
import Ecosystem        from "@/components/sections/Ecosystem.astro";
import Innovation       from "@/components/sections/Innovation.astro";
import CommunityCTA     from "@/components/sections/CommunityCTA.astro";
import FeaturedCards    from "@/components/sections/FeaturedCards.astro";
import Stats            from "@/components/sections/Stats.astro";
import Footer           from "@/components/Footer.astro";
---
<RootLayout>
  <Nav />
  <main>
    <Hero />
    <Vision />
    <Metrics />
    <TechEvolution />
    <TechStack />
    <Features />
    <EndToEndStack />
    <CoreProduct />
    <Ecosystem />
    <Innovation />
    <CommunityCTA />
    <FeaturedCards />
    <Stats />
  </main>
  <Footer />
</RootLayout>
