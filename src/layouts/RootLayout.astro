---
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "OpenxAI — The Open and Borderless AI Network",
  description = "OpenxAI makes intelligence open, programmable, and liquid. Anyone, anywhere can create, own, consume, and exchange AI as a shared global utility.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
