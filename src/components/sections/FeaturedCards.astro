---
import Reveal from "@/components/Reveal.tsx";

const cards = [
  {
    tag:   'AI Infra · GenAI',
    title: 'OpenxAI × NVIDIA Developer AMA',
    desc:  'Panel with NVIDIA technologist and OpenxAI leadership on infrastructure for permissionless AI.',
    img:   '/images/AEoiMLig9IVtQnt2bJJBwuUcjc.png',
    href:  'https://medium.com/openxai/nvidia-ama',
  },
  {
    tag:   'Manifesto',
    title: 'Why Permissionless AI',
    desc:  'A clear-eyed look at centralization risks and corporate gatekeeping of intelligence.',
    img:   '/images/Hgx97SMDIKWIT1uBOpnMV53sFA.webp',
    href:  'https://medium.com/openxai/why-permissionless-ai',
  },
  {
    tag:   'Philosophy',
    title: "OpenxAI's 10 Commandments",
    desc:  'The philosophical foundations and technical mechanisms behind the network.',
    img:   '/images/Z5OszLlxmHsIw2bna9jcghgPl0.png',
    href:  'https://medium.com/openxai/10-commandments',
  },
];
---
<section class="px-4 md:px-6 py-12 bg-brand-bg">
  <Reveal client:visible className="max-w-7xl mx-auto rounded-4xl bg-brand-panel text-brand-ink px-6 md:px-16 py-20 md:py-28">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {cards.map((c) => (
        <a
          href={c.href}
          target="_blank"
          rel="noopener"
          class="group block rounded-3xl overflow-hidden bg-brand-panel-2 hover:bg-white transition-all"
        >
          <div class="aspect-[16/10] overflow-hidden bg-brand-surface">
            <img src={c.img} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-6">
            <p class="text-[11px] uppercase tracking-[0.18em] text-brand-orange">{c.tag}</p>
            <h3 class="mt-3 text-xl md:text-2xl font-medium tracking-[-0.01em] leading-tight text-brand-ink">{c.title}</h3>
            <p class="mt-3 text-sm text-brand-ink-3">{c.desc}</p>
            <p class="mt-5 text-sm text-brand-ink/80 group-hover:text-brand-ink transition-colors">Explore more <span aria-hidden="true">→</span></p>
          </div>
        </a>
      ))}
    </div>
  </Reveal>
</section>
