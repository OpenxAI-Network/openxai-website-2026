---
import Reveal from "@/components/Reveal.tsx";

const pillars = [
  {
    label: 'Resource / Tokenization',
    title: 'Compute Liquidity (tGPUs)',
    desc:  'Tokenized compute as a liquid asset.',
    img:   '/images/34ktNn6cyVPYUhxf3ADHEy5NT9o.webp',
  },
  {
    label: 'Immutable Hosting & Training',
    title: 'Sovereign AI',
    desc:  'Permissionless, unstoppable AI services.',
    img:   '/images/ArL3Ws7StCqVKQ3K3v6laNqZ0.webp',
  },
  {
    label: 'Access / Transport',
    title: 'P2P AI Service Layer',
    desc:  'Publish & consume AI directly, no middlemen.',
    img:   '/images/PFRpepfh0iJ6hEcdaKuT5sXjOSY.webp',
  },
  {
    label: 'Tokenization / Commerce',
    title: 'Tokenization & Monetization',
    desc:  'On-chain payments, royalties, revenue-share.',
    img:   '/images/ENKtGwEpS3aY4X3Uzu2RHxOX0w.webp',
  },
];
---
<section class="px-4 md:px-6 py-12 bg-brand-bg">
  <Reveal client:visible className="max-w-7xl mx-auto rounded-4xl bg-brand-ink-2 px-6 md:px-12 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {pillars.map((p) => (
        <article class="group relative overflow-hidden rounded-3xl bg-brand-bg ring-1 ring-white/10 hover:ring-white/25 transition-all">
          <div class="aspect-[4/3] overflow-hidden bg-brand-surface">
            <img src={p.img} alt="" class="w-full h-full object-cover opacity-95 group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-6">
            <p class="text-[11px] uppercase tracking-[0.18em] text-brand-fg/55">{p.label}</p>
            <h3 class="mt-3 text-xl md:text-2xl font-medium tracking-[-0.01em] text-brand-fg">{p.title}</h3>
            <p class="mt-2 text-sm text-brand-fg/65">{p.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </Reveal>
</section>
